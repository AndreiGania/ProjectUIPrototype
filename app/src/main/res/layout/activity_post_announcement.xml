<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6DFC9"
    android:padding="20dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#F3EBDC"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:contentPadding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/TvHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_horizontal"
                android:text="Post an Announcement"
                android:textColor="#2F241D"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_input_round_light"
                android:hint="Announcement title..."
                android:paddingHorizontal="16dp"
                android:textColor="#2F241D"
                android:textColorHint="#8B7E6B"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_input_round_light"
                android:gravity="top|start"
                android:hint="Type your announcement..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#2F241D"
                android:textColorHint="#8B7E6B"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnPublish"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#3C2A21"
                android:text="Publish"
                android:textAllCaps="false"
                android:textColor="#F8F1E4"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#D4A017"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>