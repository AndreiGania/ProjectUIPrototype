<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6DFC9">

    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="#F3EBDC"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Manager"
                android:textColor="#2F241D"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDashboardSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Manage cafe operations"
                android:textColor="#7A6E62"
                android:textSize="15sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="22dp"
                android:background="#D8C8AA" />

            <Button
                android:id="@+id/btnManageShifts"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="6dp"
                android:backgroundTint="#D4A017"
                android:text="Manage Shifts"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPostAnnouncement"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D4A017"
                android:text="Post Announcement"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnViewAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D4A017"
                android:text="View Announcements"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnInventory"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#D4A017"
                android:text="Inventory"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnManageUsers"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#3C2A21"
                android:text="Manage Users"
                android:textAllCaps="false"
                android:textColor="#F8F1E4"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>