<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6DFC9"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/editCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#F3EBDC"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:contentPadding="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/pa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="10dp"
                android:text="Add/Update Inventory"
                android:textColor="#2F241D"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:text="Enter item name and quantity"
                android:textColor="#7A6E62"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input_round_light"
                android:hint="Item Name"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textColor="#2F241D"
                android:textColorHint="#8B7E6B" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Quantity"
                android:textColor="#7A6E62"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="#EDE3D1"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="6dp">

                <Button
                    android:id="@+id/btnQtyMinus"
                    android:layout_width="52dp"
                    android:layout_height="40dp"
                    android:backgroundTint="#3C2A21"
                    android:text="-"
                    android:textColor="#F8F1E4"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:ignore="TouchTargetSizeCheck" />

                <EditText
                    android:id="@+id/inputQty"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textColor="#2F241D"
                    android:textColorHint="#8B7E6B"
                    android:textSize="15sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <Button
                    android:id="@+id/btnQtyPlus"
                    android:layout_width="52dp"
                    android:layout_height="48dp"
                    android:backgroundTint="#3C2A21"
                    android:text="+"
                    android:textColor="#F8F1E4"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaveItem"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="#D4A017"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#2F241D"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>