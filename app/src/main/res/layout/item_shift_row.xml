<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="#D8C8AA"
    app:cardBackgroundColor="#F8F1E4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtShiftTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2026-02-20 • Cashier"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#2F241D" />

            <TextView
                android:id="@+id/txtShiftTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9:00 AM - 5:00 PM"
                android:textSize="13sp"
                android:textColor="#7A6E62"
                android:paddingTop="4dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteShift"
            android:layout_width="64dp"
            android:layout_height="42dp"
            android:backgroundTint="#3C2A21"
            android:text="✕"
            android:textColor="#F8F1E4"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            tools:ignore="TouchTargetSizeCheck" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>